<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp"
    android:layout_marginVertical="2dp"
    app:cardBackgroundColor="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="4dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/img_drag_handle"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="4dp"
            android:src="@android:drawable/ic_menu_sort_alphabetically"
            android:contentDescription="Arrastrar"
            app:tint="?android:attr/textColorSecondary" />

        <ImageButton
            android:id="@+id/btn_toggle_eye"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@android:color/transparent"
            android:src="@android:drawable/ic_menu_view"
            android:contentDescription="Alternar visibilidad"
            app:tint="?android:attr/textColorPrimary" />

        <EditText
            android:id="@+id/edit_nombre"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.2"
            android:hint="Nombre"
            android:textSize="14sp"
            android:inputType="textCapWords"
            android:singleLine="true"
            android:background="@android:color/transparent"
            android:textColor="?android:attr/textColorPrimary"
            android:padding="8dp"/>

        <EditText
            android:id="@+id/edit_precio"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.8"
            android:hint="Precio"
            android:textSize="14sp"
            android:inputType="number"
            android:singleLine="true"
            android:background="@android:color/transparent"
            android:textColor="?android:attr/textColorPrimary"
            android:padding="8dp"/>

        <EditText
            android:id="@+id/edit_cantidad"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.6"
            android:hint="Cant."
            android:textSize="14sp"
            android:inputType="number"
            android:singleLine="true"
            android:background="@android:color/transparent"
            android:textColor="?android:attr/textColorPrimary"
            android:padding="8dp"/>

        <ImageButton
            android:id="@+id/btn_delete"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:contentDescription="Eliminar"
            android:src="@android:drawable/ic_menu_delete"
            app:tint="#FF4444" />

    </LinearLayout>
</androidx.cardview.widget.CardView>